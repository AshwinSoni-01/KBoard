<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:paddingBottom="32dp"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="AI Writing Tools"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp"
            android:paddingStart="4dp"/>
        <Button
            android:id="@+id/btn_close_ai"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/bg_ai_chip"
            android:text="Close"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:paddingHorizontal="12dp"
            android:layout_marginHorizontal="6dp" />
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp">

            <Button android:id="@+id/btn_tool_proofread"
                android:layout_width="wrap_content" android:layout_height="40dp"
                android:background="@drawable/bg_ai_chip" android:text="Fix Grammar"
                android:textAllCaps="false" android:layout_marginHorizontal="6dp" android:paddingHorizontal="16dp"/>

            <Button android:id="@+id/btn_tool_rewrite"
                android:layout_width="wrap_content" android:layout_height="40dp"
                android:background="@drawable/bg_ai_chip" android:text="Rewrite"
                android:textAllCaps="false" android:layout_marginHorizontal="6dp" android:paddingHorizontal="16dp"/>

            <Button android:id="@+id/btn_tone_professional"
                android:layout_width="wrap_content" android:layout_height="40dp"
                android:background="@drawable/bg_ai_chip" android:text="Professional"
                android:textAllCaps="false" android:layout_marginHorizontal="6dp" android:paddingHorizontal="16dp"/>

            <Button android:id="@+id/btn_tone_friendly"
                android:layout_width="wrap_content" android:layout_height="40dp"
                android:background="@drawable/bg_ai_chip" android:text="Friendly"
                android:textAllCaps="false" android:layout_marginHorizontal="6dp" android:paddingHorizontal="16dp"/>
        </LinearLayout>
    </HorizontalScrollView>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="8dp">

        <View
            android:id="@+id/ai_glow_border"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_ai_glow"
            android:alpha="0" />

        <TextView
            android:id="@+id/tv_ai_output"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_ai_output"
            android:padding="12dp"
            android:textSize="15sp"
            android:hint="AI output will appear here..." />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp">

        <Button android:id="@+id/btn_copy_text"
            android:layout_width="wrap_content" android:layout_height="40dp"
            android:background="@drawable/bg_ai_chip"
            android:text="Copy" android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:paddingHorizontal="20dp"
            android:layout_marginHorizontal="6dp" />
 
        <Button android:id="@+id/btn_commit_text"
            android:layout_width="wrap_content" android:layout_height="40dp"
            android:background="@drawable/bg_ai_chip"
            android:text="Replace" android:textColor="#8AB4F8"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:paddingHorizontal="20dp"
            android:layout_marginHorizontal="6dp" />
    </LinearLayout>
 
    <Space
        android:layout_width="match_parent"
        android:layout_height="32dp" />
</LinearLayout>
