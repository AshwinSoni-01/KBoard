<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/klipyPanelRoot"
    android:layout_width="match_parent"
    android:layout_height="600dp"
    android:layout_gravity="bottom"
    android:orientation="vertical"
    android:background="@android:color/transparent">

    <!-- Search bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/klipyBackButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:background="@drawable/ic_back_circle"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="@string/abc_action_bar_up_description"
            app:tint="@color/textColorPrimary"
            android:layout_marginEnd="8dp" />

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:paddingHorizontal="12dp"
            android:background="@drawable/search_bar_bg">
            <EditText
                android:id="@+id/klipySearchBar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="@string/klipy_search_hint"
                android:padding="0dp"
                android:background="@null"
                android:textColor="@color/textColorPrimary"
                android:textColorHint="@color/foreground_weak"
                android:textColorHighlight="@android:color/transparent"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:autofillHints="none"
                android:stateListAnimator="@null" />
        </FrameLayout>
    </LinearLayout>

    <!-- Tabs for GIFs / Stickers -->
    <LinearLayout
        android:id="@+id/klipyTabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginHorizontal="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/tabGifs"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="@string/tab_gifs"
            android:textColor="@color/textColorPrimary"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/tab_background_selector"
            android:gravity="center"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_tab_gif"
            app:iconSize="24dp"
            app:iconPadding="8dp"
            app:iconGravity="textStart"
            app:iconTint="@color/textColorPrimary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/tabStickers"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="@string/tab_stickers"
            android:textColor="@color/textColorPrimary"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/tab_background_selector"
            android:gravity="center"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_tab_stickers"
            app:iconSize="24dp"
            app:iconPadding="8dp"
            app:iconGravity="textStart"
            app:iconTint="@color/textColorPrimary" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/klipyViewPager"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/emptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/no_recent_items"
            android:textColor="@color/textColorPrimary"
            android:visibility="gone" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/loadingIndicator"
            style="@style/Widget.Material3.CircularProgressIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>
